{
  "manifest_version": 3,
  "name": "Bookmark Manager Sync",
  "version": "1.0.0",
  "description": "将浏览器书签同步到 bookmark-manager-admin",

  "permissions": [
    "bookmarks",
    "tabs",
    "activeTab",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "http://localhost:9001/*",
    "http://127.0.0.1:9001/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Bookmark Manager Sync",
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "resources/icon-16.png",
    "48": "resources/icon-48.png",
    "128": "resources/icon-128.png"
  }
}
